# 复制为 .env 后填入你的密钥（不要提交真实密钥到仓库）。
# VITE_ 前缀的会注入前端；也可不填，改在应用「设置」里临时填（仅存浏览器本地）。
# Open-Meteo、中央气象台、广州市气象局无需密钥。

# 和风天气开发版 Key：https://dev.qweather.com
VITE_QWEATHER_KEY=

# 彩云天气 Token：https://platform.caiyunapp.com
VITE_CAIYUN_KEY=

# The Weather Channel（weather.com）v3 apiKey
VITE_TWC_KEY=

# ---- Apple WeatherKit（服务端使用，切勿加 VITE_ 前缀，否则会泄露到前端）----
# 需要 Apple 开发者账号并启用 WeatherKit。生产环境请在 Cloudflare 项目里配置为加密变量。
APPLE_TEAM_ID=
APPLE_SERVICE_ID=
APPLE_KEY_ID=
# .p8 私钥内容（PEM）。单行写法可把换行写成 \n，例如：
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIG..."
APPLE_PRIVATE_KEY=
